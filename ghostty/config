# ---------------------------------------
#   フォント
# ---------------------------------------
# Nerd Font 対応フォント（アイコン表示に必要）
font-family = JetBrainsMono Nerd Font

# ---------------------------------------
#   テーマ
# ---------------------------------------
# ダークテーマ（Catppuccin Mocha）
theme = Catppuccin Mocha

# ---------------------------------------
#   ウィンドウ
# ---------------------------------------
# 左右の内側余白
window-padding-x = 8
# 上下の内側余白
window-padding-y = 8
# タイトルバーを非表示にしてすっきりさせる
macos-titlebar-style = hidden

# ---------------------------------------
#   背景
# ---------------------------------------
# 背景色（カスタムカラー）
background = #031219
# background-opacity = 0.9
# 背景ブラーの強度（macOS のみ有効）
background-blur-radius = 20

# ---------------------------------------
#   カーソル
# ---------------------------------------
# カーソル形状: block / bar / underline
cursor-style = block
# カーソルの点滅を有効化
cursor-style-blink = true

# ---------------------------------------
#   シェル統合
# ---------------------------------------
# fish shell との統合を有効化
shell-integration = fish

# ---------------------------------------
#  クリップボード
# ---------------------------------------
# copy-on-select = true
# 選択時にシステムクリップボードへ直接コピー
copy-on-select = clipboard

# ---------------------------------------
#   macOS 固有設定
# ---------------------------------------
# 左 Option キーを Alt として扱う（Neovim 等で必要）
macos-option-as-alt = left
# Alt+←/→ のデフォルトバインドを解除（シェル/エディタに委譲）
keybind = alt+left=unbind
keybind = alt+right=unbind
